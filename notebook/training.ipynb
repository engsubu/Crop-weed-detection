!pip install ultralytics

# Cell 2: Imports
from ultralytics import YOLO

# Cell 3: Train
model = YOLO('yolov8n.pt')
results = model.train(
    data='../data.yaml', 
    epochs=50, 
    imgsz=512,
    project='../models',
    name='crop_weed_yolov8n'
)

# Cell 4: Validate
model.val()

# Cell 5: Predict
model.predict(source='../data/images/val', save=True, conf=0.4)
