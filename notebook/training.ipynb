!pip install ultralytics

# Cell 2: Mount Drive and unzip dataset
from google.colab import drive
drive.mount('/content/drive')
!unzip '/content/drive/MyDrive/crop_weed_dataset.zip' -d '/content/dataset'

# Cell 3: Train
from ultralytics import YOLO
model = YOLO('yolov8n.pt')
model.train(data='data.yaml', epochs=50, imgsz=512)

# Cell 4: Validate
model.val()

# Cell 5: Predict
model.predict(source='/content/dataset/images/val', save=True)
